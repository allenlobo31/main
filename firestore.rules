rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    // True when the logged-in user IS the document owner.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // True when the logged-in user is the patient's linked doctor.
    function isLinkedDoctor(userId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(userId))
        && (
          (get(/databases/$(database)/documents/users/$(userId)).data.linkedDoctorId != null && 
           request.auth.uid == get(/databases/$(database)/documents/users/$(userId)).data.linkedDoctorId) ||
          (get(/databases/$(database)/documents/users/$(userId)).data.linkedDoctorIds != null && 
           request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.linkedDoctorIds) ||
          (get(/databases/$(database)/documents/users/$(userId)).data.pendingDoctorIds != null && 
           request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.pendingDoctorIds)
        );
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    // Patient: full read + write on own profile.
    // Doctor : read-only on linked patients.

    match /users/{userId} {
      // Allow reading patient profiles if logged in (for doctor selection)
      // Allow reading doctor profiles for patients
      allow read:   if isAuthenticated(); 
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingPatientIds', 'pendingDoctorIds', 'linkedPatientIds', 'linkedDoctorIds']));
      allow delete: if false;

      // Allow direct access to certain fields for linked/pending users
      // This is needed for atomic updates (arrayUnion/arrayRemove) when the other user updates their side
      // specifically when using `updateDoc` on a document the user doesn't own.
      // But actually in Firestore security rules, `update` is checked against the whole document.
      // Let's refine the update rule to allow specific array operations from authenticated users.
      // Reference: "could not accept patient" often happens because one side fails.


      // ── Symptoms ──────────────────────────────────────────────────────────
      // Patient: read + create (no manual update/delete — AI writes via Admin SDK).
      // Doctor : read-only.
      match /symptoms/{entryId} {
        allow read:   if isOwner(userId) || isLinkedDoctor(userId);
        allow create: if isOwner(userId);
        allow update: if false;   // Cloud Functions update aiFlag via Admin SDK
        allow delete: if false;
      }

      // ── Diary ─────────────────────────────────────────────────────────────
      // Patient: full read + write.
      // Doctor : read-only.
      match /diary/{entryId} {
        allow read:   if isOwner(userId) || isLinkedDoctor(userId);
        allow create: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // ── Reports ───────────────────────────────────────────────────────────
      // Patient: read + create + delete (no update — AI writes via Admin SDK).
      // Doctor : read-only.
      match /reports/{reportId} {
        allow read:   if isOwner(userId) || isLinkedDoctor(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
        allow update: if false;   // Cloud Functions update aiWoundAnalysis
      }

      // ── Gamification ──────────────────────────────────────────────────────
      // Patient: full read + write (XP, streaks, badges).
      // Doctor : read-only.
      match /gamification/{doc} {
        allow read:   if isOwner(userId) || isLinkedDoctor(userId);
        allow write:  if isOwner(userId);
      }
    }

    // ── Experts ───────────────────────────────────────────────────────────────
    // Any authenticated user can browse the expert directory (read-only).
    match /experts/{expertId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Doctor Contacts ─────────────────────────────────────────────────────
    // Any authenticated user can read quick-call doctor contacts.
    match /doctorContacts/{contactId} {
      allow read:  if isAuthenticated();
      allow write: if false;
    }

    // ── Consultations ────────────────────────────────────────────────────────
    // Only the patient or expert in the call can read.
    // Writes are handled by Cloud Functions only.
    match /consultations/{consultationId} {
      allow read: if request.auth.uid == resource.data.patientId
                  || request.auth.uid == resource.data.expertId;
      allow write: if false;
    }

    // ── AI Insights ──────────────────────────────────────────────────────────
    // Patient: read their own daily insights.
    // Doctor : read linked patient's insights.
    // Writes: Cloud Functions only (via Admin SDK).
    match /aiInsights/{userId}/daily/{date} {
      allow read:  if isOwner(userId) || isLinkedDoctor(userId);
      allow write: if false;
    }

    // ── Error logs ───────────────────────────────────────────────────────────
    // Any authenticated user can create error logs; nobody reads them from client.
    match /errors/{errorId} {
      allow read:  if false;
      allow write: if isAuthenticated();
    }
  }
}
