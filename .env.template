# ─── HerniaCare Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── Firebase ────────────────────────────────────────────────────────────────
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Agora ───────────────────────────────────────────────────────────────────
AGORA_APP_ID=your_agora_app_id
# NOTE: Agora App Certificate lives in Firebase Secret Manager only
# Never put it here — handled via Firebase Cloud Functions

# ─── Claude / Anthropic ──────────────────────────────────────────────────────
# NOTE: Anthropic API Key lives in Firebase Secret Manager only
# Never put it here — Claude is always called via Cloud Functions

# ─── EAS / Expo ──────────────────────────────────────────────────────────────
EAS_PROJECT_ID=your_eas_project_id
