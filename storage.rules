rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Reports ──────────────────────────────────────────────────────────────
    // Patient: read + write their own reports (max 20 MB, images and PDFs only).
    // Doctor : read-only on linked patient's reports.
    match /reports/{userId}/{reportId}/{filename} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
          || firestore.get(/databases/(default)/documents/users/$(userId)).data.linkedDoctorId == request.auth.uid);

      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 20 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf');
    }

    // ── Avatars ──────────────────────────────────────────────────────────────
    // Any authenticated user can view avatars.
    // Only the owner can upload their own avatar (max 5 MB, images only).
    match /avatars/{userId}/{filename} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
